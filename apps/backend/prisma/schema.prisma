generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  evaluations Evaluation[]

  @@map("projects")
}

model Criterion {
  id          String        @id @default(uuid())
  name        String
  description String
  weight      Float
  type        CriterionType
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  evaluations Evaluation[]

  @@map("criteria")
}

model Evaluation {
  id             String        @id @default(uuid())
  projectId      String
  criterionId    String
  linguisticTerm String
  fuzzyValue     Float
  label          String
  alpha          Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criterion Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([projectId, criterionId])
  @@map("evaluations")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(DECISOR)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum CriterionType {
  BENEFIT
  COST
}

enum UserRole {
  ADMIN
  DECISOR
  VIEWER
}

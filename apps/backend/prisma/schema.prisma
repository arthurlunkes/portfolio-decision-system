generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Portfolio {
  id                   String                @id @default(uuid())
  name                 String
  description          String                @default("")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  projects             Project[]
  criteria             Criterion[]
  rankings             Ranking[]
  decissorPortfolios   DecissorPortfolio[]
  criterionImportances CriterionImportance[]

  @@map("portfolios")
}

model Project {
  id          String        @id @default(uuid())
  portfolioId String
  name        String
  description String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  portfolio   Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]
  positions   RankingPosition[]

  @@map("projects")
}

model Criterion {
  id               String                  @id @default(uuid())
  portfolioId      String
  name             String
  description      String
  // peso calculado automaticamente a partir das avaliações de importância dos decisores
  // ωj = Δj / Σ(Δk); NULL = ainda não calculado
  group            String                  @default("")
  weight           Float                   @default(0)
  type             CriterionType
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  portfolio        Portfolio               @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  evaluations      Evaluation[]
  importances      CriterionImportance[]

  @@map("criteria")
}

// Avaliação de IMPORTÂNCIA dos critérios pelos decisores
// Escala: EN(0) IN(1) PI(2) OI(3) IM(4) MI(5) EM(6)
model CriterionImportance {
  id             String    @id @default(uuid())
  criterionId    String
  evaluatorId    String
  portfolioId    String
  linguisticTerm String
  numericValue   Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  criterion      Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  evaluator      User      @relation("EvaluatorImportances", fields: [evaluatorId], references: [id], onDelete: Cascade)
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([criterionId, evaluatorId])
  @@map("criterion_importances")
}

model Evaluation {
  id             String   @id @default(uuid())
  projectId      String
  criterionId    String
  evaluatorId    String
  linguisticTerm String
  fuzzyValue     Float
  label          String
  alpha          Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criterion Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  evaluator User      @relation("EvaluatorEvaluations", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([projectId, criterionId, evaluatorId])
  @@map("evaluations")
}

model User {
  id                 String               @id @default(uuid())
  name               String
  email              String               @unique
  passwordHash       String
  role               UserRole             @default(DECISOR)
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  evaluations          Evaluation[]          @relation("EvaluatorEvaluations")
  decissorPortfolios   DecissorPortfolio[]   @relation("DecissorPortfolios")
  criterionImportances CriterionImportance[] @relation("EvaluatorImportances")

  @@map("users")
}

// Vínculo avaliador-portfólio com peso linguístico de expertise (λk)
// Escala: EN(0) IN(1) PI(2) OI(3) IM(4) MI(5) EM(6)
// Default: IM = 4 → pesos iguais quando todos os decisores têm o mesmo grau
model DecissorPortfolio {
  id               String    @id @default(uuid())
  portfolioId      String
  evaluatorId      String
  weightLinguistic String    @default("IM")
  weightNumeric    Float     @default(4)
  weightNormalized Float     @default(1.0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  evaluator        User      @relation("DecissorPortfolios", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, evaluatorId])
  @@map("decissor_portfolio")
}

model Ranking {
  id          String            @id @default(uuid())
  portfolioId String
  executedAt  DateTime          @default(now())
  v           Float             @default(0.5)
  portfolio   Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  positions   RankingPosition[]

  @@map("rankings")
}

model RankingPosition {
  id          String   @id @default(uuid())
  rankingId   String
  projectId   String
  sValue      Float
  rValue      Float
  qValue      Float
  rank        Int
  c1Satisfied Boolean
  c2Satisfied Boolean
  ranking     Ranking  @relation(fields: [rankingId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ranking_positions")
}

model CustomRole {
  id          String   @id
  name        String   @unique
  label       String
  description String   @default("")
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_roles")
}

enum CriterionType {
  BENEFIT
  COST
}

enum UserRole {
  ADMIN
  DECISOR
  ANALYST
  VIEWER
}
